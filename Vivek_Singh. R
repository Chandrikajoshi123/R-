# Extended version: robust add function with error handling
safe_add <- function(a, b) {
  if (!is.numeric(a) || !is.numeric(b)) {
    stop("Both arguments must be numeric.")
  }
  result <- a + b
  cat(sprintf("  safe_add(%g, %g) = %g\n", a, b, result))
  invisible(result)
}

cat("\nRobust Addition Tests:\n")
safe_add(10, 20)
safe_add(-5, 3.14)
safe_add(1e6, 2e6)

# tryCatch for invalid input
tryCatch(
  safe_add("hello", 5),
  error = function(e) cat(sprintf("  Caught error: %s\n", e$message))
)
